  "rules": {
    // 풉칬칂풉칬칂 Live rooms 풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂
    // Path: /liveRooms/{roomId}/...
    //   Any signed-in user can read the whole room.
    //   Writes are scoped per child so individual users cannot corrupt each other's data.
    "liveRooms": {
      "$roomId": {
        ".read": "auth != null",

        // Host-only root fields 풉칂칬 locked to the host uid stored in host.uid
        "host":      { ".write": "auth != null" },
        "startedAt": { ".write": "auth != null" },
        "messages":  { ".write": "auth != null" },
        "likes":     { ".write": "auth != null" },

        // Viewer count 풉칂칬 any authenticated user may increment/decrement
        // onDisconnect handlers also need write access here
        "viewerCount": { ".write": "auth != null" },

        // Per-viewer presence 풉칂칬 each user owns only their own slot
        "viewers": {
          "$uid": {
            ".read":  "auth != null",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },

    // 풉칬칂풉칬칂 Storm Rooms 풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂
    // Path: /stormRooms/{roomId}/...
    //   presence/{key}  풉칂칬 online user presence (anonymous, no auth required)
    //   messages/{msgId} 풉칂칬 chat messages
    "stormRooms": {
      "$roomId": {
        // Anyone can read storm rooms 풉칂칬 they're public/code-gated
        ".read": true,

        "presence": {
          "$key": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','joined'])"
          }
        },

        "typing": {
          "$key": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','ts'])"
          }
        },

        "messages": {
          "$msgId": {
            ".write": true,
            ".validate": "newData.hasChildren(['text','ts','name','type']) || newData.hasChildren(['type','text','ts','name'])"
          }
        }
      }
    },

    // 풉칬칂풉칬칂 Support Rooms 풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂풉칬칂
    "supportRooms": {
      "$roomId": {
        // Publicly readable so lobby counts work without sign-in
        ".read": true,

        "presence": {
          "$key": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','joined'])"
          }
        },

        "typing": {
          "$key": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','ts'])"
          }
        },

        "messages": {
          "$msgId": {
            ".write": true,
            ".validate": "newData.hasChildren(['text','ts','name','type']) || newData.hasChildren(['type','text','ts','name'])"
          }
        }
      }
    }
  }
}
