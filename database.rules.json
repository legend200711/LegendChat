{
  "rules": {
    // ── Live rooms ─────────────────────────────────────────────────────────────
    // Path: /liveRooms/{roomId}/...
    //   Any signed-in user can read the whole room.
    //   Writes are scoped per child so individual users cannot corrupt each other's data.
    "liveRooms": {
      "$roomId": {
        ".read": "auth != null",

        // Host-only root fields (host, startedAt) — written once when going live
        "host":       { ".write": "auth != null" },
        "startedAt":  { ".write": "auth != null" },

        // Viewer count — any authenticated user may increment/decrement
        "viewerCount": { ".write": "auth != null" },

        // Per-viewer presence — each user owns only their own slot
        "viewers": {
          "$uid": {
            ".read":  "auth != null",
            ".write": "auth != null && auth.uid === $uid"
          }
        },

        // Chat messages — any authenticated user may push a new message
        // (path used by live.js: liveRooms/{roomId}/messages)
        "messages": {
          ".read":  "auth != null",
          "$msgId": { ".write": "auth != null" }
        },

        // Likes counter — any authenticated user may increment
        "likes": { ".write": "auth != null" }
      }
    },

    // ── Storm Rooms ─────────────────────────────────────────────────────────────
    // Path: /stormRooms/{roomId}/...
    //   presence/{key}  — online user presence (anonymous, no auth required)
    //   messages/{msgId} — chat messages
    "stormRooms": {
      "$roomId": {
        // Anyone can read storm rooms — they're public/code-gated
        ".read": true,

        "presence": {
          "$key": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','joined'])"
          }
        },

        "typing": {
          "$key": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','ts'])"
          }
        },

        "messages": {
          "$msgId": {
            ".write": true,
            ".validate": "newData.hasChildren(['text','ts','name','type']) || newData.hasChildren(['type','text','ts','name'])"
          }
        }
      }
    },

    // ── Support Rooms ───────────────────────────────────────────────────────────
    "supportRooms": {
      "$roomId": {
        // Publicly readable so lobby counts work without sign-in
        ".read": true,

        "presence": {
          "$key": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','joined'])"
          }
        },

        "typing": {
          "$key": {
            ".write": true,
            ".validate": "newData.hasChildren(['name','ts'])"
          }
        },

        "messages": {
          "$msgId": {
            ".write": true,
            ".validate": "newData.hasChildren(['text','ts','name','type']) || newData.hasChildren(['type','text','ts','name'])"
          }
        }
      }
    }
  }
}
